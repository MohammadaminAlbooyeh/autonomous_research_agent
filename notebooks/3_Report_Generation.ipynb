   "source": ["# Report Generation\n\nThis notebook demonstrates how the agent generates structured reports from research findings."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["import sys\nsys.path.append('..')\n\nfrom backend.agents.report_generator import ReportGeneratorAgent\nfrom backend.tools.citation_manager import CitationManagerTool\n\ngenerator = ReportGeneratorAgent()\ncitation_tool = CitationManagerTool()"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## Generating a Report from Findings\n\nProvide findings and sources to generate a structured report."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["findings = [\n", "    {\"claim\": \"GPT-4 demonstrates advanced reasoning capabilities across multiple domains\", \"confidence\": 0.92},\n", "    {\"claim\": \"Multimodal AI models are becoming increasingly prevalent in enterprise applications\", \"confidence\": 0.88},\n", "    {\"claim\": \"Open-source LLMs are closing the gap with proprietary models\", \"confidence\": 0.85},\n", "]\n", "\n", "sources = [\n", "    {\"url\": \"https://arxiv.org/abs/2303.08774\", \"title\": \"GPT-4 Technical Report\", \"author\": \"OpenAI\"},\n", "    {\"url\": \"https://example.com/multimodal-ai\", \"title\": \"Multimodal AI Survey\", \"author\": \"Research Lab\"},\n", "]\n", "\n", "report = generator.generate_report(\"AI Advancements 2025\", findings, sources)\n", "\n", "print(f\"Title: {report['title']}\")"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["print(\"EXECUTIVE SUMMARY\")\n", "print(report['executive_summary'])\n", "print(\"\\n\" + \"=\"*50)\n", "for section in report['sections']:\n", "    print(f\"\\n## {section['heading']}\")\n", "    print(section['content'][:300] + \"...\")"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": ["print(\"\\nREFERENCES\")\n", "for c in report['citations']:\n", "    print(f\"  - {c}\")"]
  }
