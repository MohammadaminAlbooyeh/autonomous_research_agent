# OpenAI API key (optional - enables LLM-powered summarization and report generation)
OPENAI_API_KEY=

# Google Custom Search API (optional - enables real web search; uses mock data if empty)
GOOGLE_API_KEY=
GOOGLE_CX=

# Database URL (defaults to SQLite if not set)
DATABASE_URL=sqlite:///./research_agent.db

# JWT Secret Key (change this to a strong random string in production)
SECRET_KEY=your-secret-key-change-in-production

# Database Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# PostgreSQL credentials (for docker-compose deployment)
POSTGRES_PASSWORD=secure_password_change_me

# Grafana admin password
GRAFANA_PASSWORD=admin_password_change_me

